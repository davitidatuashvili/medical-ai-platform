    "class_mapping": {
        "0": "NORMAL",
        "1": "PNEUMONIA"
    },
    "output_activation": "sigmoid",
    "loss": "binary_crossentropy",
    "threshold": 0.5,
    "preprocessing": "Rescaling from 0-255 to -1..1 inside the model"
}